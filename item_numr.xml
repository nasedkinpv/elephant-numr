<?xml version="1.0" encoding="UTF-8"?>
<interface>
  <requires lib="gtk" version="4.0"></requires>
  <object class="GtkBox" id="ItemBox">
    <style>
      <class name="item-box"></class>
      <class name="numr-item"></class>
    </style>
    <property name="orientation">horizontal</property>
    <property name="spacing">0</property>
    <child>
      <!-- Left column: Result -->
      <object class="GtkBox" id="NumrResultColumn">
        <style>
          <class name="numr-result-column"></class>
        </style>
        <property name="orientation">vertical</property>
        <property name="valign">center</property>
        <property name="hexpand">true</property>
        <child>
          <object class="GtkLabel" id="ItemText">
            <style>
              <class name="item-text"></class>
              <class name="numr-result"></class>
            </style>
            <property name="ellipsize">end</property>
            <property name="xalign">0</property>
            <property name="hexpand">true</property>
          </object>
        </child>
      </object>
    </child>
    <child>
      <!-- Separator -->
      <object class="GtkSeparator" id="NumrSeparator">
        <style>
          <class name="numr-separator"></class>
        </style>
        <property name="orientation">vertical</property>
      </object>
    </child>
    <child>
      <!-- Right column: Info -->
      <object class="GtkBox" id="NumrInfoColumn">
        <style>
          <class name="numr-info-column"></class>
        </style>
        <property name="orientation">vertical</property>
        <property name="valign">center</property>
        <property name="halign">end</property>
        <child>
          <object class="GtkLabel" id="ItemSubtext">
            <style>
              <class name="item-subtext"></class>
              <class name="numr-info"></class>
            </style>
            <property name="xalign">1</property>
            <property name="halign">end</property>
          </object>
        </child>
      </object>
    </child>
  </object>
</interface>
